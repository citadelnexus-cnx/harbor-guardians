{
  "name": "harbor-guardians",
  "version": "0.0.0",
  "private": true,
  "description": "Harbor Guardians — standalone city-builder × RPG hybrid. Milestone 0 scaffold.",
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "schema:generate": "node scripts/generate-schema.mjs",
    "schema:validate": "node scripts/validate-data.mjs",
    "sim:harness": "tsx sim-harness/run.ts",
    "test:save": "tsx --test tests/save-load.test.ts",
    "test:harbor": "tsx --test tests/harbor-state.test.ts",
    "test:ledger": "tsx --test tests/claim-ledger.test.ts",
    "test:events": "tsx --test tests/event-lifecycle.test.ts",
    "test:expedition": "tsx --test tests/expedition.test.ts",
    "test:ui": "tsx --test tests/ui-controller.test.ts",
    "ui:engine": "tsc -p tsconfig.engine.json",
    "ui:playthrough": "tsx scripts/build-playthrough.mts",
    "ui:build": "pnpm run ui:engine && pnpm run ui:playthrough",
    "tauri": "tauri"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "22.20.1",
    "ajv": "8.20.0",
    "oxlint": "1.74.0",
    "ts-json-schema-generator": "2.9.0",
    "tsx": "4.20.3",
    "typescript": "^5.8.3"
  }
}
