{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Harbor Guardians",
  "version": "0.0.0",
  "identifier": "app.citadelnexus.harbor-guardians",
  "build": {
    "frontendDist": "../src/ui/shell"
  },
  "app": {
    "windows": [
      {
        "title": "Harbor Guardians — M0 Shell",
        "width": 1024,
        "height": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'"
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
