{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git fetch:*)",
      "Bash(pnpm install:*)",
      "Bash(pnpm run:*)",
      "Bash(pnpm exec:*)",
      "Bash(node:*)",
      "Bash(cargo check:*)",
      "Bash(cargo build:*)",
      "Bash(gh pr:*)",
      "Bash(gh repo view:*)",
      "PowerShell(git status:*)",
      "PowerShell(git diff:*)",
      "PowerShell(git log:*)",
      "PowerShell(git add:*)",
      "PowerShell(git commit:*)",
      "PowerShell(git push:*)",
      "PowerShell(git branch:*)",
      "PowerShell(git checkout:*)",
      "PowerShell(git fetch:*)",
      "PowerShell(pnpm install:*)",
      "PowerShell(pnpm run:*)",
      "PowerShell(pnpm exec:*)",
      "PowerShell(node:*)",
      "PowerShell(cargo check:*)",
      "PowerShell(cargo build:*)",
      "PowerShell(gh pr:*)",
      "PowerShell(gh repo view:*)",
      "Read(./**)",
      "Edit(./**)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(curl * | sh*)",
      "Bash(curl * | bash*)",
      "Bash(wget * | sh*)",
      "Bash(wget * | bash*)",
      "PowerShell(rm -rf:*)",
      "PowerShell(git push --force:*)",
      "PowerShell(git push -f:*)",
      "PowerShell(git reset --hard:*)",
      "PowerShell(iwr * | iex*)",
      "PowerShell(irm * | iex*)",
      "PowerShell(Invoke-WebRequest * | Invoke-Expression*)",
      "PowerShell(Invoke-RestMethod * | Invoke-Expression*)",
      "PowerShell(Invoke-WebRequest * | iex*)",
      "PowerShell(Invoke-RestMethod * | iex*)"
    ]
  }
}
